{
  "scripts": {
    "start": "wp-scripts start --webpack-copy-php",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "i18n-pot": "wp i18n make-pot . languages/3d-viewer.pot --exclude=\"src,zip,public\"",
    "i18n-json": "wp i18n make-json languages/ --no-purge",
    "i18n-mo": "wp i18n make-mo languages/",
    "i18n": "npm run i18n-pot && npm run copy && npm run i18n-json && npm run i18n-mo",
    "copy": "cp ./languages/3d-viewer.pot ./languages/3d-viewer-en_US.po",
    "cp": "cp ./languages/3d-viewer.pot ./languages/3d-viewer-en_US.po",
    "build": "wp-scripts build --webpack-copy-php && npm run i18n && find . -name '.DS_Store' -delete && npm run zip",
    "sync": "browser-sync start -p 'http://localhost/freemius' --files '**/*.php' 'dist/*.js' 'dist/*.css'",
    "zip": "rm -f zip/3d-viewer.zip && zip -r zip/3d-viewer.zip 3d-viewer-block/ admin/ build/ inc languages public vendor 3d-viewer.php readme.txt composer.json uninstall.php",
    "clean": "find . -name '.DS_Store' -type f -delete",
    "preview": "npm-run-all --parallel sync start",
    "bundle": "gulp bundle && gulp zip",
    "deploy": "gulp freemius-deploy"
  },
  "dependencies": {
    "@fancyapps/ui": "^5.0.36",
    "@wordpress/element": "^6.40.0",
    "bp-utils": "^0.0.13",
    "immer": "^10.1.1",
    "lucide-react": "^0.542.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.7.1",
    "react-toastify": "^11.0.5",
    "swiper": "^11.2.10",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wordpress__api-fetch": "^3.23.1",
    "@types/wordpress__block-editor": "^15.0.5",
    "@types/wordpress__element": "^2.14.1",
    "@types/wordpress__hooks": "^2.11.0",
    "@types/wordpress__i18n": "^3.11.0",
    "@wordpress/block-editor": "^14.21.0",
    "@wordpress/blocks": "^13.10.0",
    "@wordpress/components": "^28.13.0",
    "@wordpress/compose": "^7.27.0",
    "@wordpress/data": "^10.27.0",
    "@wordpress/i18n": "^5.26.0",
    "@wordpress/scripts": "^27.9.0",
    "@wp-playground/cli": "^3.1.15",
    "eslint-webpack-plugin": "^4.2.0",
    "gulp": "^5.0.1",
    "gulp-freemius-deploy": "^1.0.11",
    "typescript": "^5.9.3"
  }
}